{
  "name": "@twomilia/web",
  "version": "0.1.0",
  "description": "Thin, typed loader for the Twomilia web agent. Loads the runtime from the CDN (like @stripe/stripe-js) — no heavy bundle.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "twomilia",
    "ai",
    "support",
    "agent",
    "chatbot",
    "widget",
    "sdk"
  ],
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
